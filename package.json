{
  "name": "aoe4-replay-share-api-charts",
  "private": true,
  "type": "module",
  "scripts": {
    "build:data": "node build/build-pbgid-map.mjs",
    "build:data:strict": "node build/build-pbgid-map.mjs --strict",
    "build:content": "node build/build-content.mjs",
    "build": "npm run build:data && npm run build:content",
    "dev": "node build/build-content.mjs --watch",
    "pack": "npm run build && cd chrome-extension && npx bestzip ../chrome-extension-store.zip .",
    "test:fixtures": "node --experimental-strip-types tests/check-fixtures.mjs",
    "test:adversarial": "node --experimental-strip-types tests/check-adversarial.mjs",
    "test:unit": "node --experimental-strip-types --test \"tests/unit/*.test.mjs\"",
    "test:regression": "node --experimental-strip-types --test \"tests/regression/*.test.mjs\"",
    "test": "npm run test:fixtures && npm run test:adversarial && npm run build:content && node --experimental-strip-types --test \"tests/unit/*.test.mjs\" \"tests/regression/*.test.mjs\"",
    "coverage": "node --experimental-strip-types --experimental-test-coverage --test-coverage-include=\"src/**\" --test \"tests/unit/*.test.mjs\" \"tests/regression/*.test.mjs\"",
    "test:integration": "node tests/integration/extension.test.cjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "esbuild": "^0.28.0",
    "linkedom": "^0.18.12",
    "typescript": "^6.0.3"
  }
}
